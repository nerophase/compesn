{
	"name": "compesn-workspace",
	"private": true,
	"repository": {
		"type": "git",
		"url": "https://github.com/nerophase/compesn.git"
	},
	"packageManager": "pnpm@10.28.1",
	"scripts": {
		"build": "pnpm -r build",
		"build:shared": "pnpm --filter ./compesn-shared build",
		"build:frontend": "pnpm --filter ./compesn-frontend build",
		"build:backend": "pnpm --filter ./compesn-backend build",
		"dev:frontend": "pnpm --filter ./compesn-frontend dev",
		"dev:backend": "pnpm --filter ./compesn-backend dev",
		"lint": "pnpm -r lint",
		"postinstall": "pnpm build:shared",
		"start:frontend": "pnpm --filter ./compesn-frontend start",
		"start:backend": "pnpm --filter ./compesn-backend start",
		"typecheck": "pnpm -r typecheck",
		"test": "pnpm -r test"
	}
}
